# RR Engenharia — Apache Configuration

# Enable Rewrite Engine
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# 301 Redirects — URLs antigas (estrutura anterior do site) para as novas.
# Recupera o histórico de SEO e elimina os erros 404 no Search Console.
RewriteRule ^servicos/instalacao-sasc/?$        /servicos/sasc.html [R=301,L]
RewriteRule ^servicos/teste-estanqueidade/?$    /servicos/teps.html [R=301,L]
RewriteRule ^blog/o-que-e-sasc/?$               /blog/o-que-e-sasc-guia-completo.html [R=301,L]
RewriteRule ^blog/teps-ensaios-estanqueidade/?$ /blog/inspecao-teps-o-que-sua-empresa-precisa-saber.html [R=301,L]
RewriteRule ^blog/manutencao-preventiva-sla/?$  /servicos/manutencao-predial.html [R=301,L]
RewriteRule ^blog/obras-postos-combustivel/?$   /servicos/postos-de-combustivel.html [R=301,L]
RewriteRule ^blog/rr-engine-automacao-propostas/?$ /blog/ [R=301,L]
RewriteRule ^contato/?$                          /contato.html [R=301,L]

# Custom Error Pages
ErrorDocument 404 /index.html

# GZIP Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML não é cacheado: o navegador sempre revalida, então mudanças no
  # conteúdo aparecem na hora. Imagens/CSS/JS mantêm cache longo (têm ?v=).
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType application/json "access plus 1 day"
</IfModule>

# HTML sempre revalidado (evita servir página desatualizada após deploy)
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Prevent directory listing
Options -Indexes

# UTF-8 encoding
AddDefaultCharset UTF-8

# MIME types
AddType image/svg+xml .svg .svgz
AddType application/json .json
AddType text/xml .xml
